{
  "version": 2,
  "rewrites": [
    {
      "source": "/((?!assets|favicon\\.png|favicon\\.ico).*)",
      "destination": "/api/index"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}